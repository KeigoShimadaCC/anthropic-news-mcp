# Required only for running the eval suite (evals/run_eval.py)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: raises GitHub API rate limit from 60 to 5,000 req/hr
# Get one at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=ghp_...

# Optional: override local SQLite cache path
ANTHROPIC_NEWS_MCP_CACHE_DB=/var/lib/anthropic-news-mcp/cache.db

# Required only for remote Streamable HTTP ASGI deployments
ANTHROPIC_NEWS_MCP_AUTH_ISSUER=https://issuer.example
ANTHROPIC_NEWS_MCP_AUTH_AUDIENCE=anthropic-news
ANTHROPIC_NEWS_MCP_REQUIRED_SCOPES=anthropic-news:read
ANTHROPIC_NEWS_MCP_ALLOWED_HOSTS=mcp.example.com
ANTHROPIC_NEWS_MCP_ALLOWED_ORIGINS=https://client.example
ANTHROPIC_NEWS_MCP_RESOURCE_SERVER_URL=https://mcp.example.com
